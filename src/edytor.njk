}

[data-theme="light"] .save-success-message code {
  background-color: #f8f9fa;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Set today's date as default
  const dateInput = document.getElementById('post-date');
  const today = new Date().toISOString().split('T')[0];
  dateInput.value = today;
  
  // Initialize EasyMDE
  const easyMDE = new EasyMDE({
    element: document.getElementById('post-content'),
    spellChecker: false,
    autofocus: false,
    placeholder: 'Treść wpisu...',
    toolbar: [
      'bold', 'italic', 'heading', '|',
      'quote', 'unordered-list', 'ordered-list', '|',
      'link', 'image', 'code', 'table', '|',
      'preview', 'side-by-side', 'fullscreen', '|',
      'guide'
    ],
    shortcuts: {
      'togglePreview': 'Cmd-P'
    },
    status: ['lines', 'words', 'cursor'],
    minHeight: '400px',
    renderingConfig: {
      singleLineBreaks: false,
      codeSyntaxHighlighting: true,
    }
  });
  
  // Store uploaded images
  let uploadedImages = [];
  let featuredImageFile = null;
  
  // Featured Image Upload
  const featuredUploadArea = document.getElementById('featured-upload-area');
  const featuredFileInput = document.getElementById('featured-file-input');
  const featuredImageUrl = document.getElementById('featured-image-url');
  const featuredImageAlt = document.getElementById('featured-image-alt');
  const featuredPreview = document.getElementById('featured-image-preview');
  const featuredPreviewImg = document.getElementById('featured-image-preview-img');
  const featuredFilename = document.getElementById('featured-image-filename');
  const removeFeaturedBtn = document.getElementById('remove-featured-image');
  
  // Drag & Drop for featured image
  featuredUploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    featuredUploadArea.classList.add('drag-over');
  });
  
  featuredUploadArea.addEventListener('dragleave', () => {
    featuredUploadArea.classList.remove('drag-over');
  });
  
  featuredUploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    featuredUploadArea.classList.remove('drag-over');
    const files = e.dataTransfer.files;
    if (files.length > 0) {
      handleFeaturedFile(files[0]);
    }
  });
  
  featuredFileInput.addEventListener('change', (e) => {
    if (e.target.files.length > 0) {
      handleFeaturedFile(e.target.files[0]);
    }
  });
  
  function handleFeaturedFile(file) {
    if (!file.type.startsWith('image/')) {
      alert('Proszę wybrać plik obrazka (PNG, JPG, GIF, SVG)');
      return;
    }
    if (file.size > 5 * 1024 * 1024) {
      alert('Plik jest za duży. Maksymalny rozmiar to 5MB.');
      return;
    }
    
    featuredImageFile = file;
    const reader = new FileReader();
    reader.onload = (e) => {
      featuredPreviewImg.src = e.target.result;
      featuredFilename.textContent = file.name;
      featuredPreview.style.display = 'inline-flex';
      featuredImageUrl.value = `/assets/images/${file.name}`;
    };
    reader.readAsDataURL(file);
  }
  
  removeFeaturedBtn.addEventListener('click', function() {
    featuredImageFile = null;
    featuredImageUrl.value = '';
    featuredImageAlt.value = '';
    featuredPreview.style.display = 'none';
    featuredPreviewImg.src = '';
    featuredFilename.textContent = '';
    featuredFileInput.value = '';
  });
  
  // Content Images Upload
  const contentUploadArea = document.getElementById('content-upload-area');
  const contentFileInput = document.getElementById('content-file-input');
  const uploadedImagesList = document.getElementById('uploaded-images-list');
  const imagesGrid = document.getElementById('images-grid');
  
  contentUploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    contentUploadArea.classList.add('drag-over');
  });
  
  contentUploadArea.addEventListener('dragleave', () => {
    contentUploadArea.classList.remove('drag-over');
  });
  
  contentUploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    contentUploadArea.classList.remove('drag-over');
    handleContentFiles(e.dataTransfer.files);
  });
  
  contentFileInput.addEventListener('change', (e) => {
    handleContentFiles(e.target.files);
  });
  
  function handleContentFiles(files) {
    Array.from(files).forEach(file => {
      if (!file.type.startsWith('image/')) return;
      if (file.size > 5 * 1024 * 1024) {
        alert(`Plik ${file.name} jest za duży. Pominięto.`);
        return;
      }
      
      const reader = new FileReader();
      reader.onload = (e) => {
        const imageData = {
          file: file,
          name: file.name,
          dataUrl: e.target.result,
          url: `/assets/images/${file.name}`
        };
        uploadedImages.push(imageData);
        renderUploadedImages();
      };
      reader.readAsDataURL(file);
    });
  }
  
  function renderUploadedImages() {
    if (uploadedImages.length === 0) {
      uploadedImagesList.style.display = 'none';
      return;
    }
    
    uploadedImagesList.style.display = 'block';
    imagesGrid.innerHTML = '';
    
    uploadedImages.forEach((img, index) => {
      const item = document.createElement('div');
      item.className = 'uploaded-image-item';
      item.innerHTML = `
        <img src="${img.dataUrl}" alt="${img.name}">
        <div class="image-name">${img.name}</div>
        <button type="button" class="image-remove" data-index="${index}" title="Usuń">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      `;
      
      item.addEventListener('click', (e) => {
        if (!e.target.closest('.image-remove')) {
          // Select image and fill URL
          document.getElementById('insert-image-url').value = img.url;
          document.querySelectorAll('.uploaded-image-item').forEach(el => el.classList.remove('selected'));
          item.classList.add('selected');
        }
      });
      
      item.querySelector('.image-remove').addEventListener('click', (e) => {
        e.stopPropagation();
        uploadedImages.splice(index, 1);
        renderUploadedImages();
      });
      
      imagesGrid.appendChild(item);
    });
  }
  
  // Tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(`tab-${btn.dataset.tab}`).classList.add('active');
    });
  });
  
  // Insert Image Button
  document.getElementById('insert-image-btn').addEventListener('click', function() {
    const url = document.getElementById('insert-image-url').value.trim();
    const alt = document.getElementById('insert-image-alt').value.trim();
    const title = document.getElementById('insert-image-title').value.trim();
    const width = document.getElementById('insert-image-width').value.trim();
    const align = document.getElementById('insert-image-align').value;
    
    if (!url || !alt) {
      alert('Proszę podać URL obrazka i tekst alternatywny (alt).');
      return;
    }
    
    // Build markdown image syntax
    let imageMarkdown = '';
    
    // Add alignment wrapper if specified
    if (align) {
      const alignClass = align === 'center' ? 'text-center' : `float-${align}`;
      imageMarkdown += `<div class="${alignClass}">\n\n`;
    }
    
    // Build image markdown
    if (title) {
      imageMarkdown += `![${alt}](${url} "${title}")`;
    } else {
      imageMarkdown += `![${alt}](${url})`;
    }
    
    // Add width attribute if specified
    if (width) {
      imageMarkdown = imageMarkdown.replace(')', `){width="${width}px"}`);
    }
    
    if (align) {
      imageMarkdown += '\n\n</div>';
    }
    
    // Insert at cursor position
    const cm = easyMDE.codemirror;
    const doc = cm.getDoc();
    const cursor = doc.getCursor();
    
    doc.replaceRange('\n\n' + imageMarkdown + '\n\n', cursor);
    
    // Clear inputs
    document.getElementById('insert-image-url').value = '';
    document.getElementById('insert-image-alt').value = '';
    document.getElementById('insert-image-title').value = '';
    document.getElementById('insert-image-width').value = '';
    document.getElementById('insert-image-align').value = '';
    
    // Show success
    const btn = this;
    const originalText = btn.innerHTML;
    btn.innerHTML = `
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      Wstawiono!
    `;
    btn.classList.add('is-success');
    setTimeout(() => {
      btn.innerHTML = originalText;
      btn.classList.remove('is-success');
    }, 1500);
  });
  
  // Generate Markdown function
  function generateMarkdown() {
    const title = document.getElementById('post-title').value.trim();
    const date = document.getElementById('post-date').value;
    const tagsInput = document.getElementById('post-tags').value.trim();
    const description = document.getElementById('post-description').value.trim();
    const content = easyMDE.value().trim();
    const featuredImg = featuredImageUrl.value.trim();
    const featuredImgAlt = featuredImageAlt.value.trim();
    
    if (!title || !date || !description || !content) {
      alert('Proszę wypełnić wszystkie wymagane pola (oznaczone *).');
      return null;
    }
    
    // Process tags
    const tags = tagsInput
      ? tagsInput.split(',').map(t => t.trim()).filter(t => t).map(t => `  - ${t}`).join('\n')
      : '';
    
    // Build frontmatter
    let markdown = `---\n`;
    markdown += `title: ${title}\n`;
    markdown += `description: ${description}\n`;
    markdown += `date: ${date}\n`;
    if (tags) {
      markdown += `tags:\n${tags}\n`;
    }
    if (featuredImg) {
      markdown += `image: ${featuredImg}\n`;
    }
    markdown += `---\n\n`;
    
    // Add featured image at the top if exists
    if (featuredImg) {
      markdown += `![${featuredImgAlt || title}](${featuredImg})\n\n`;
    }
    
    markdown += content;
    
    return { markdown, title, date };
  }
  
  // Generate and Download
  document.getElementById('generate-btn').addEventListener('click', function() {
    const result = generateMarkdown();
    if (!result) return;
    
    const { markdown, title, date } = result;
    
    // Generate slug
    const slug = title
      .toLowerCase()
      .replace(/[ąäâàá]/g, 'a')
      .replace(/[ćčç]/g, 'c')
      .replace(/[ęèéêë]/g, 'e')
      .replace(/[ł]/g, 'l')
      .replace(/[ńñ]/g, 'n')
      .replace(/[óôòö]/g, 'o')
      .replace(/[śš]/g, 's')
      .replace(/[źżž]/g, 'z')
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .substring(0, 50);
    
    // Show output
    document.getElementById('output-content').textContent = markdown;
    document.getElementById('output-section').style.display = 'block';
    document.getElementById('instructions-panel').style.display = 'block';
    
    // Download file
    const blob = new Blob([markdown], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${date}-${slug}.md`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });
  
  // Download ZIP with images
  document.getElementById('download-zip-btn').addEventListener('click', async function() {
    const result = generateMarkdown();
    if (!result) return;
    
    const { markdown, title, date } = result;
    
    // Generate slug
    const slug = title
      .toLowerCase()
      .replace(/[ąäâàá]/g, 'a')
      .replace(/[ćčç]/g, 'c')
      .replace(/[ęèéêë]/g, 'e')
      .replace(/[ł]/g, 'l')
      .replace(/[ńñ]/g, 'n')
      .replace(/[óôòö]/g, 'o')
      .replace(/[śš]/g, 's')
      .replace(/[źżž]/g, 'z')
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .substring(0, 50);
    
    // Create ZIP
    const zip = new JSZip();
    
    // Add markdown file
    zip.file(`${date}-${slug}.md`, markdown);
    
    // Add images folder
    const imagesFolder = zip.folder('images');
    
    // Add featured image if exists
    if (featuredImageFile) {
      imagesFolder.file(featuredImageFile.name, featuredImageFile);
    }
    
    // Add content images
    uploadedImages.forEach(img => {
      imagesFolder.file(img.file.name, img.file);
    });
    
    // Add README with instructions
    const readme = `# Instrukcja instalacji

## Pliki w tym archiwum:
- \`${date}-${slug}.md\` - wpis na blog
- \`images/\` - folder z obrazkami

## Jak dodać wpis do bloga:

1. Wypakuj zawartość ZIP
2. Skopiuj plik \`.md\` do folderu \`src/posts/\`
3. Skopiuj wszystkie obrazki z folderu \`images/\` do \`src/assets/images/\`
4. Uruchom w terminalu: \`npm run build\`
5. Wgraj zmiany na GitHub: \`git add . && git commit -m "Nowy wpis" && git push\`

Gotowe! Wpis pojawi się na blogu po kilku minutach.`;
    
    zip.file('README.txt', readme);
    
    // Generate and download ZIP
    const zipBlob = await zip.generateAsync({ type: 'blob' });
    const zipUrl = URL.createObjectURL(zipBlob);
    const a = document.createElement('a');
    a.href = zipUrl;
    a.download = `${date}-${slug}.zip`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(zipUrl);
    
    // Show output and instructions
    document.getElementById('output-content').textContent = markdown;
    document.getElementById('output-section').style.display = 'block';
    document.getElementById('instructions-panel').style.display = 'block';
  });
  
  // Load MD file
  document.getElementById('load-md-btn').addEventListener('click', function() {
    document.getElementById('load-md-input').click();
  });
  
  document.getElementById('load-md-input').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    
    const reader = new FileReader();
    reader.onload = function(event) {
      const content = event.target.result;
      parseMarkdownFile(content, file.name);
    };
    reader.readAsText(file);
  });
  
  function parseMarkdownFile(content, filename) {
    // Parse frontmatter
    const frontmatterMatch = content.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
    
    if (!frontmatterMatch) {
      alert('Nie udało się sparsować pliku. Upewnij się, że ma poprawny format frontmatter (---).');
      return;
    }
    
    const frontmatter = frontmatterMatch[1];
    const bodyContent = frontmatterMatch[2].trim();
    
    // Parse frontmatter fields
    const titleMatch = frontmatter.match(/title:\s*(.+)/);
    const dateMatch = frontmatter.match(/date:\s*(\d{4}-\d{2}-\d{2})/);
    const descriptionMatch = frontmatter.match(/description:\s*(.+)/);
    const tagsMatch = frontmatter.match(/tags:\n((?:\s+-\s*.+\n?)+)/);
    const imageMatch = frontmatter.match(/image:\s*(.+)/);
    
    // Fill form fields
    if (titleMatch) {
      document.getElementById('post-title').value = titleMatch[1].trim();
    }
    
    if (dateMatch) {
      document.getElementById('post-date').value = dateMatch[1].trim();
    }
    
    if (descriptionMatch) {
      document.getElementById('post-description').value = descriptionMatch[1].trim();
    }
    
    if (tagsMatch) {
      const tags = tagsMatch[1].match(/-\s*(.+)/g);
      if (tags) {
        document.getElementById('post-tags').value = tags.map(t => t.replace(/^-\s*/, '').trim()).join(', ');
      }
    }
    
    // Handle featured image
    if (imageMatch) {
      const imgUrl = imageMatch[1].trim();
      document.getElementById('featured-image-url').value = imgUrl;
      
      // Try to extract alt text from body if exists
      const imgRegex = new RegExp(`!\\[(.*?)\\]\\(${imgUrl.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\)`);
      const imgInBody = bodyContent.match(imgRegex);
      if (imgInBody) {
        document.getElementById('featured-image-alt').value = imgInBody[1] || '';
      }
      
      // Show preview if it's a URL
      if (imgUrl.startsWith('http') || imgUrl.startsWith('/')) {
        document.getElementById('featured-image-preview-img').src = imgUrl;
        document.getElementById('featured-image-filename').textContent = imgUrl.split('/').pop();
        document.getElementById('featured-image-preview').style.display = 'inline-flex';
      }
    }
    
    // Set content (remove featured image from top if present to avoid duplication)
    let cleanContent = bodyContent;
    if (imageMatch) {
      const imgUrl = imageMatch[1].trim();
      const imgRegex = new RegExp(`^!\\[.*?\\]\\(${imgUrl.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\)\n\n`);
      cleanContent = bodyContent.replace(imgRegex, '');
    }
    
    easyMDE.value(cleanContent);
    
    // Show success message
    const btn = document.getElementById('load-md-btn');
    const originalText = btn.innerHTML;
    btn.innerHTML = `
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      Wczytano!
    `;
    btn.classList.add('is-success');
    setTimeout(() => {
      btn.innerHTML = originalText;
      btn.classList.remove('is-success');
    }, 2000);
    
    // Show instructions
    document.getElementById('instructions-panel').style.display = 'block';
    document.getElementById('instructions-panel').querySelector('.instructions-content').innerHTML = `
      <p><strong>✓ Wczytano plik: ${filename}</strong></p>
      <p>Sprawdź czy wszystkie pola są poprawnie wypełnione, a następnie:</p>
      <ol>
        <li>Edytuj treść w edytorze</li>
        <li>Kliknij "Pobierz plik .md" lub "Pobierz ZIP"</li>
        <li>Zastąp stary plik w projekcie nowym</li>
      </ol>
    `;
  }
  
  // Copy to clipboard
  document.getElementById('copy-btn').addEventListener('click', function() {
    const result = generateMarkdown();
    if (!result) return;
    
    navigator.clipboard.writeText(result.markdown).then(() => {
      const btn = document.getElementById('copy-btn');
      const originalText = btn.innerHTML;
      btn.innerHTML = `
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        Skopiowano!
      `;
      setTimeout(() => {
        btn.innerHTML = originalText;
      }, 2000);
    });
  });
  
  // Toggle preview
  document.getElementById('toggle-preview').addEventListener('click', function() {
    const previewSection = document.getElementById('preview-section');
    const previewContent = document.getElementById('preview-content');
    const content = easyMDE.value();
    
    if (previewSection.style.display === 'none') {
      previewContent.innerHTML = easyMDE.markdown(content);
      previewSection.style.display = 'block';
      this.innerHTML = `
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
        Ukryj podgląd
      `;
    } else {
      previewSection.style.display = 'none';
      this.innerHTML = `
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
        Podgląd
      `;
    }
  });
});
</script>
