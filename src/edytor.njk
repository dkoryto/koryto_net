---
layout: layouts/base.njk
title: Edytor WYSIWYG
permalink: /edytor/
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde@2.18.0/dist/easymde.min.css">
<script src="https://cdn.jsdelivr.net/npm/easymde@2.18.0/dist/easymde.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>

<section class="section editor-section">
  <div class="container editor-container">
    <h1 class="section__title">Edytor WYSIWYG</h1>
    <p class="editor-intro">Twórz wpisy na blog w wizualny sposób. Możesz dodać obrazki z URL lub przesłać je lokalnie.</p>
    
    <form id="post-form" class="editor-form">
      <div class="editor-field">
        <label for="post-title" class="editor-label">Tytuł wpisu *</label>
        <input type="text" id="post-title" name="title" class="editor-input" placeholder="np. Jak stworzyłem tego bloga" required>
      </div>
      
      <div class="editor-row">
        <div class="editor-field editor-field--half">
          <label for="post-date" class="editor-label">Data publikacji *</label>
          <input type="date" id="post-date" name="date" class="editor-input" required>
        </div>
        
        <div class="editor-field editor-field--half">
          <label for="post-tags" class="editor-label">Tagi (oddzielone przecinkami)</label>
          <input type="text" id="post-tags" name="tags" class="editor-input" placeholder="np. 11ty, tutorial, webdev">
        </div>
      </div>
      
      <div class="editor-field">
        <label for="post-description" class="editor-label">Opis (wyświetlany w listach) *</label>
        <textarea id="post-description" name="description" class="editor-textarea" rows="2" placeholder="Krótki opis wpisu, max 2-3 zdania..." required></textarea>
      </div>

      <!-- Featured Image Section with File Upload -->
      <div class="editor-field">
        <label class="editor-label">Obrazek wyróżniający (Featured Image)</label>
        
        <!-- Upload Area -->
        <div class="upload-area" id="featured-upload-area">
          <input type="file" id="featured-file-input" class="file-input" accept="image/*">
          <div class="upload-content">
            <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
            <p><strong>Kliknij aby wybrać plik</strong> lub przeciągnij i upuść</p>
            <span class="upload-hint">PNG, JPG, GIF, SVG (max 5MB)</span>
          </div>
        </div>
        
        <!-- OR Divider -->
        <div class="or-divider">
          <span>LUB</span>
        </div>
        
        <!-- URL Input -->
        <div class="url-input-section">
          <input type="text" id="featured-image-url" class="editor-input" placeholder="URL obrazka zewnętrznego, np. https://...">
        </div>
        
        <!-- Alt Text -->
        <input type="text" id="featured-image-alt" class="editor-input image-alt-input" placeholder="Tekst alternatywny (alt) - ważne dla SEO i dostępności">
        
        <!-- Preview -->
        <div class="image-preview" id="featured-image-preview" style="display: none;">
          <img src="" alt="Preview" id="featured-image-preview-img">
          <div class="image-info">
            <span id="featured-image-filename"></span>
            <button type="button" class="image-remove-btn" id="remove-featured-image" title="Usuń obrazek">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>
      </div>
      
      <div class="editor-field">
        <label for="post-content" class="editor-label">Treść wpisu *</label>
        <div class="editor-toolbar-hint">
          <span>💡 Użyj ikon w pasku narzędzi lub składni Markdown:</span>
          <code># Nagłówek</code>
          <code>**pogrubienie**</code>
          <code>*kursywa*</code>
          <code>[link](url)</code>
          <code>![obraz](url)</code>
          <code>```kod```</code>
        </div>
        <textarea id="post-content" name="content" class="editor-textarea editor-textarea--large" placeholder="Treść wpisu..." required></textarea>
      </div>

      <!-- Image Upload Panel for Content -->
      <div class="image-upload-panel">
        <h3 class="image-upload-title">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <circle cx="8.5" cy="8.5" r="1.5"></circle>
            <polyline points="21 15 16 10 5 21"></polyline>
          </svg>
          Dodaj obrazek do treści
        </h3>
        
        <div class="image-upload-tabs">
          <button type="button" class="tab-btn active" data-tab="upload-local">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
            Z komputera
          </button>
          <button type="button" class="tab-btn" data-tab="upload-url">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
            Z URL
          </button>
        </div>
        
        <!-- Local Upload Tab -->
        <div class="tab-content active" id="tab-upload-local">
          <div class="upload-area upload-area--small" id="content-upload-area">
            <input type="file" id="content-file-input" class="file-input" accept="image/*" multiple>
            <div class="upload-content">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <polyline points="21 15 16 10 5 21"></polyline>
              </svg>
              <p><strong>Wybierz obrazki</strong> lub przeciągnij tutaj</p>
            </div>
          </div>
        </div>
        
        <!-- URL Tab -->
        <div class="tab-content" id="tab-upload-url">
          <div class="image-insert-grid">
            <div class="image-insert-field">
              <label for="insert-image-url">URL obrazka *</label>
              <input type="text" id="insert-image-url" class="editor-input" placeholder="https://example.com/obrazek.jpg">
            </div>
            <div class="image-insert-field">
              <label for="insert-image-alt">Tekst alternatywny (alt) *</label>
              <input type="text" id="insert-image-alt" class="editor-input" placeholder="Opis obrazka dla SEO">
            </div>
            <div class="image-insert-field">
              <label for="insert-image-title">Tytuł (title)</label>
              <input type="text" id="insert-image-title" class="editor-input" placeholder="Tekst po najechaniu">
            </div>
            <div class="image-insert-field image-insert-field--small">
              <label for="insert-image-width">Szerokość (px)</label>
              <input type="number" id="insert-image-width" class="editor-input" placeholder="np. 800">
            </div>
            <div class="image-insert-field image-insert-field--small">
              <label for="insert-image-align">Wyrównanie</label>
              <select id="insert-image-align" class="editor-input">
                <option value="">Domyślnie</option>
                <option value="left">Do lewej</option>
                <option value="center">Wyśrodkowane</option>
                <option value="right">Do prawej</option>
              </select>
            </div>
          </div>
        </div>
        
        <!-- Uploaded Images List -->
        <div class="uploaded-images-list" id="uploaded-images-list" style="display: none;">
          <h4>Przesłane obrazki:</h4>
          <div class="images-grid" id="images-grid"></div>
        </div>
        
        <button type="button" id="insert-image-btn" class="btn btn--secondary btn--small">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Wstaw obrazek do treści
        </button>
      </div>
      
      <div class="editor-preview-toggle">
        <button type="button" id="toggle-preview" class="btn btn--secondary">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
          Podgląd
        </button>
      </div>
      
      <div id="preview-section" class="editor-preview" style="display: none;">
        <h3 class="editor-preview__title">Podgląd:</h3>
        <div id="preview-content" class="editor-preview__content post-content"></div>
      </div>
      
      <div class="editor-actions">
        <button type="button" id="generate-btn" class="btn btn--primary">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Pobierz plik .md
        </button>
        <button type="button" id="download-zip-btn" class="btn btn--secondary">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
          </svg>
          Pobierz ZIP (.md + obrazki)
        </button>
        <button type="button" id="load-md-btn" class="btn btn--secondary">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="12" y1="18" x2="12" y2="12"></line>
            <line x1="9" y1="15" x2="15" y2="15"></line>
          </svg>
          Wczytaj .md
        </button>
        <input type="file" id="load-md-input" accept=".md,.markdown" style="display: none;">
        <button type="button" id="copy-btn" class="btn btn--secondary">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          Kopiuj do schowka
        </button>
        <button type="reset" class="btn btn--ghost">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"></polyline>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
          </svg>
          Wyczyść
        </button>
      </div>
      
      <div id="output-section" class="editor-output" style="display: none;">
        <h3 class="editor-output__title">Wygenerowany Markdown:</h3>
        <pre id="output-content" class="editor-output__code"></pre>
      </div>
      
      <!-- Instructions Panel -->
      <div class="instructions-panel" id="instructions-panel" style="display: none;">
        <h3 class="instructions-title">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
          </svg>
          Instrukcja instalacji
        </h3>
        <div class="instructions-content">
          <p>Aby dodać wpis do bloga:</p>
          <ol>
            <li>Pobierz plik ZIP (zawiera wpis + obrazki)</li>
            <li>Wypakuj zawartość do folderu projektu:</li>
            <ul>
              <li>Plik <code>.md</code> → <code>src/posts/</code></li>
              <li>Obrazki → <code>src/assets/images/</code></li>
            </ul>
            <li>Uruchom <code>npm run build</code></li>
            <li>Wgraj zmiany na GitHub</li>
          </ol>
        </div>
      </div>
    </form>
  </div>
</section>

<style>
.editor-section {
  padding: var(--space-xl) 0;
}

.editor-container {
  max-width: 900px;
}

.editor-intro {
  color: var(--color-text-muted);
  margin-bottom: var(--space-lg);
  font-size: 1.125rem;
}

.editor-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.editor-field {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.editor-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-md);
}

@media (max-width: 600px) {
  .editor-row {
    grid-template-columns: 1fr;
  }
}

.editor-label {
  font-weight: 600;
  color: var(--color-text);
  font-size: 0.9375rem;
}

.editor-input,
.editor-textarea,
.editor-select {
  padding: 0.75rem 1rem;
  background-color: var(--color-surface);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--border-radius-sm);
  color: var(--color-text);
  font-family: inherit;
  font-size: 1rem;
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}

.editor-input:focus,
.editor-textarea:focus,
.editor-select:focus {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
}

.editor-textarea {
  resize: vertical;
  min-height: 100px;
}

.editor-textarea--large {
  min-height: 400px;
  font-family: var(--font-mono);
  font-size: 0.9375rem;
  line-height: 1.6;
}

.editor-hint {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  margin-top: 0.25rem;
}

/* Upload Area */
.upload-area {
  position: relative;
  border: 2px dashed rgba(255, 255, 255, 0.2);
  border-radius: var(--border-radius);
  padding: var(--space-xl);
  text-align: center;
  cursor: pointer;
  transition: all var(--transition-fast);
  background-color: var(--color-surface);
}

.upload-area:hover,
.upload-area.drag-over {
  border-color: var(--color-primary);
  background-color: rgba(99, 102, 241, 0.05);
}

.upload-area--small {
  padding: var(--space-md);
}

.file-input {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  cursor: pointer;
}

.upload-content {
  pointer-events: none;
}

.upload-content svg {
  margin-bottom: var(--space-sm);
  color: var(--color-text-muted);
}

.upload-content p {
  color: var(--color-text);
  margin-bottom: 0.25rem;
}

.upload-hint {
  font-size: 0.8125rem;
  color: var(--color-text-muted);
}

/* OR Divider */
.or-divider {
  display: flex;
  align-items: center;
  text-align: center;
  margin: var(--space-sm) 0;
  color: var(--color-text-muted);
  font-size: 0.875rem;
}

.or-divider::before,
.or-divider::after {
  content: '';
  flex: 1;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.or-divider span {
  padding: 0 var(--space-sm);
}

/* URL Input Section */
.url-input-section {
  margin-bottom: var(--space-sm);
}

.image-alt-input {
  margin-top: var(--space-sm);
}

/* Image Preview */
.image-preview {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  max-width: 300px;
  border-radius: var(--border-radius-sm);
  overflow: hidden;
  border: 2px solid var(--color-primary);
  margin-top: var(--space-sm);
}

.image-preview img {
  width: 100%;
  height: auto;
  display: block;
  max-height: 200px;
  object-fit: cover;
}

.image-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.5rem 0.75rem;
  background-color: var(--color-surface-elevated);
  font-size: 0.8125rem;
}

.image-info span {
  color: var(--color-text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200px;
}

.image-remove-btn {
  width: 28px;
  height: 28px;
  background-color: rgba(239, 68, 68, 0.2);
  color: #ef4444;
  border: none;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
  flex-shrink: 0;
  margin-left: 0.5rem;
}

.image-remove-btn:hover {
  background-color: #ef4444;
  color: white;
}

/* Image Upload Panel */
.image-upload-panel {
  background-color: var(--color-surface);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--border-radius);
  padding: var(--space-md);
  margin: var(--space-sm) 0;
}

.image-upload-title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: var(--space-md);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

/* Tabs */
.image-upload-tabs {
  display: flex;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  padding-bottom: var(--space-xs);
}

.tab-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5rem 1rem;
  background: none;
  border: none;
  color: var(--color-text-muted);
  font-size: 0.9375rem;
  cursor: pointer;
  border-radius: var(--border-radius-sm);
  transition: all var(--transition-fast);
}

.tab-btn:hover {
  color: var(--color-text);
  background-color: rgba(255, 255, 255, 0.05);
}

.tab-btn.active {
  color: var(--color-primary-light);
  background-color: rgba(99, 102, 241, 0.1);
}

.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}

/* Image Insert Grid */
.image-insert-grid {
  display: grid;
  grid-template-columns: 2fr 2fr 1.5fr 1fr 1fr;
  gap: var(--space-sm);
}

@media (max-width: 900px) {
  .image-insert-grid {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 600px) {
  .image-insert-grid {
    grid-template-columns: 1fr;
  }
}

.image-insert-field {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

.image-insert-field label {
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--color-text-muted);
}

.image-insert-field--small {
  min-width: 100px;
}

/* Uploaded Images List */
.uploaded-images-list {
  margin: var(--space-md) 0;
  padding: var(--space-md);
  background-color: var(--color-bg);
  border-radius: var(--border-radius-sm);
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.uploaded-images-list h4 {
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: var(--space-sm);
}

.images-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: var(--space-sm);
}

.uploaded-image-item {
  position: relative;
  border-radius: var(--border-radius-sm);
  overflow: hidden;
  border: 2px solid transparent;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.uploaded-image-item:hover,
.uploaded-image-item.selected {
  border-color: var(--color-primary);
}

.uploaded-image-item img {
  width: 100%;
  height: 80px;
  object-fit: cover;
  display: block;
}

.uploaded-image-item .image-name {
  padding: 0.375rem;
  font-size: 0.75rem;
  color: var(--color-text-muted);
  background-color: var(--color-surface);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.uploaded-image-item .image-remove {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 24px;
  height: 24px;
  background-color: rgba(0, 0, 0, 0.7);
  color: white;
  border: none;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity var(--transition-fast);
}

.uploaded-image-item:hover .image-remove {
  opacity: 1;
}

/* Toolbar Hint */
.editor-toolbar-hint {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  align-items: center;
  padding: 0.75rem;
  background-color: var(--color-surface);
  border-radius: var(--border-radius-sm);
  font-size: 0.875rem;
  color: var(--color-text-muted);
}

.editor-toolbar-hint code {
  background-color: var(--color-surface-elevated);
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  font-family: var(--font-mono);
  font-size: 0.8125rem;
}

/* Preview Section */
.editor-preview-toggle {
  display: flex;
  justify-content: center;
  padding: var(--space-sm) 0;
}

