---
layout: layouts/base.njk
title: Blog
---

<section class="section">
  <div class="container">
    <h1 class="section__title">Wszystkie wpisy</h1>
    <div class="posts-grid">
      {% for post in collections.posts %}
      <article class="post-card">
        <div class="post-card__meta">
          <time datetime="{{ post.date | isoDate }}">{{ post.date | dateDisplay }}</time>
          {% if post.data.tags %}
            {% for tag in post.data.tags %}
              {% if tag != "posts" %}
              <span class="post-card__tag">{{ tag }}</span>
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
        <h2 class="post-card__title">
          <a href="{{ post.url }}">{{ post.data.title }}</a>
        </h2>
        {% if post.data.description %}
        <p class="post-card__excerpt">{{ post.data.description }}</p>
        {% endif %}
        <a href="{{ post.url }}" class="post-card__read-more">Czytaj więcej</a>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
