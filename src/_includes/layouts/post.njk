---
layout: layouts/base.njk
---

<article class="post">
  <header class="post-header">
    <div class="container container--content">
      <div class="post-meta">
        <time datetime="{{ date | isoDate }}">{{ date | dateDisplay }}</time>
        <span class="reading-time" aria-label="Czas czytania">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          {{ content | readingTime }} min czytania
        </span>
        {% if tags %}
        <span class="post-tags">
          {% for tag in tags %}
            {% if tag != "posts" %}
            <a href="{{ '/tag/' | url }}{{ tag | slugify }}/" class="tag">{{ tag }}</a>
            {% endif %}
          {% endfor %}
        </span>
        {% endif %}
      </div>
      <h1 class="post-title">{{ title }}</h1>
      {% if description %}
      <p class="post-description">{{ description }}</p>
      {% endif %}
    </div>
  </header>
  
  {% set toc = content | toc %}
  {% if toc.length > 0 %}
  <aside class="toc-wrapper" aria-label="Spis treści">
    <div class="container container--content">
      <nav class="toc" aria-label="Spis treści">
        <details class="toc-details" open>
          <summary class="toc-summary">
            <span class="toc-title">Spis treści</span>
          </summary>
          <ul class="toc-list">
            {% for heading in toc %}
            <li class="toc-item toc-item--level-{{ heading.level }}">
              <a href="#{{ heading.id }}" class="toc-link">{{ heading.text }}</a>
            </li>
            {% endfor %}
          </ul>
        </details>
      </nav>
    </div>
  </aside>
  {% endif %}
  
  <div class="post-content">
    <div class="container container--content">
      {{ content | safe }}
    </div>
  </div>
  
  {% set relatedPosts = collections.posts | hasCommonTags(tags, page.url) | limit(3) %}
  {% if relatedPosts.length > 0 %}
  <aside class="related-posts">
    <div class="container container--content">
      <h2 class="related-posts__title">Powiązane wpisy</h2>
      <div class="related-posts__grid">
        {% for related in relatedPosts %}
        <article class="related-post">
          <time datetime="{{ related.date | isoDate }}" class="related-post__date">{{ related.date | dateDisplay }}</time>
          <h3 class="related-post__title">
            <a href="{{ related.url | url }}">{{ related.data.title }}</a>
          </h3>
          {% if related.data.description %}
          <p class="related-post__excerpt">{{ related.data.description }}</p>
          {% endif %}
        </article>
        {% endfor %}
      </div>
    </div>
  </aside>
  {% endif %}
  
  <footer class="post-footer">
    <div class="container container--content">
      <nav class="post-nav" aria-label="Nawigacja postów">
        <div class="post-nav__prev">
          {% if collections.posts %}
            {% set prevPost = collections.posts | getPreviousCollectionItem %}
            {% if prevPost %}
            <a href="{{ prevPost.url }}">
              <span class="post-nav__label">← Poprzedni post</span>
              <span class="post-nav__title">{{ prevPost.data.title }}</span>
            </a>
            {% endif %}
          {% endif %}
        </div>
        <div class="post-nav__next">
          {% if collections.posts %}
            {% set nextPost = collections.posts | getNextCollectionItem %}
            {% if nextPost %}
            <a href="{{ nextPost.url }}">
              <span class="post-nav__label">Następny post →</span>
              <span class="post-nav__title">{{ nextPost.data.title }}</span>
            </a>
            {% endif %}
          {% endif %}
        </div>
      </nav>
    </div>
  </footer>
</article>
