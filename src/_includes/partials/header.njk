<header class="site-header">
  <div class="container">
    <a href="{{ '/' | url }}" class="logo" aria-label="Strona główna">
      <span class="logo__text">{{ site.author }}</span>
    </a>
    
    <nav class="main-nav" aria-label="Główna nawigacja">
      <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Przełącz menu">
        <span class="hamburger"></span>
      </button>
      
      <ul id="nav-menu" class="nav-menu" role="menubar">
        <li role="none"><a href="{{ '/' | url }}" role="menuitem" {% if page.url == "/" %}aria-current="page"{% endif %}>Home</a></li>
        <li role="none"><a href="{{ '/blog/' | url }}" role="menuitem" {% if page.url == "/blog/" %}aria-current="page"{% endif %}>Blog</a></li>
        <li role="none"><a href="{{ '/archiwum/' | url }}" role="menuitem" {% if page.url == "/archiwum/" %}aria-current="page"{% endif %}>Archiwum</a></li>
        <li role="none"><a href="{{ '/o-mnie/' | url }}" role="menuitem" {% if page.url == "/o-mnie/" %}aria-current="page"{% endif %}>O mnie</a></li>
      </ul>
      
      <a href="{{ '/search/' | url }}" class="nav-search" aria-label="Szukaj">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </a>
    </nav>
  </div>
</header>
